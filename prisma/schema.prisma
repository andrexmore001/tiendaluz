generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  id              String   @id @default("site-settings")
  title           String   @default("Artesana")
  slug            String   @default("artesana")
  logo            String?
  primaryColor    String   @default("#E8A2A2")
  secondaryColor  String   @default("#F9F1E7")
  accentColor     String   @default("#D4AF37")
  backgroundColor String   @default("#FFFFFF")
  phone           String   @default("+57 300 000 0000")
  email           String   @default("contacto@artesana.com")
  address         String   @default("Calle Falsa 123, Bogotá")
  instagram       String   @default("https://instagram.com/artesana")
  facebook        String   @default("https://facebook.com/artesana")
  heroTitle       String?
  heroSubtitle    String?
  heroImages      Json?
  chatBusinessId  String?  @default("mvp-test-123")
  chatApiKey      String?  @default("key_test_123")
  updatedAt       DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  price       Float
  category    String
  description String
  image       String?
  displayMode String      @default("3d")
  width       Float       @default(4)
  height      Float       @default(2)
  depth       Float       @default(4)
  materialId  String
  baseColor   String      @default("#F9F1E7")
  modelUrl    String?
  images      Json?
  isVisible   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  priceTiers  PriceTier[]
  material    Material    @relation(fields: [materialId], references: [id])
}

model PriceTier {
  id        String  @id @default(cuid())
  minQty    Int
  maxQty    Int?
  unitPrice Float
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
}

model Material {
  id         String    @id @default(cuid())
  name       String
  textureUrl String?
  products   Product[]
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model Quote {
  id              String      @id @default(cuid())
  quoteNumber     String      @unique
  date            DateTime    @default(now())
  expiryDate      DateTime?
  vendor          String
  clientName      String
  clientNit       String
  billingAddress  String
  shippingAddress String
  notes           String?
  paymentTerms    String?
  subtotal        Float
  total           Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           QuoteItem[]
}

model QuoteItem {
  id          String @id @default(cuid())
  description String
  qty         Int
  unitPrice   Float
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}